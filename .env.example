# ============================================================================
# SentinelQ — Environment template
# ----------------------------------------------------------------------------
# Copy this file to `.env` and fill in your secrets.
# `.env` is in .gitignore — DO NOT commit, DO NOT paste contents into chat.
#
# Convention:
#   * Paper (모의)  endpoints/keys live alongside their LIVE (실거래) twin.
#   * Loader code MUST refuse to mix: paper keys cannot submit live orders.
# ============================================================================

# ---- Active environment selector ----
# One of: paper | live
# Tooling refuses to touch the OTHER env's keys when this is set.
KIS_ENV=paper

# ---- KIS — Paper (모의투자) ----
KIS_PAPER_BASE_URL=https://openapivts.koreainvestment.com:29443
KIS_PAPER_APP_KEY=
KIS_PAPER_APP_SECRET=
KIS_PAPER_ACCOUNT_NO=        # 8-digit + 2-digit (e.g. 50000000-01)
KIS_PAPER_ACCOUNT_PRDT=01    # 종합 02 if applicable

# ---- KIS — Live (실거래) ----
KIS_LIVE_BASE_URL=https://openapi.koreainvestment.com:9443
KIS_LIVE_APP_KEY=
KIS_LIVE_APP_SECRET=
KIS_LIVE_ACCOUNT_NO=
KIS_LIVE_ACCOUNT_PRDT=01

# ---- LLM (later sprints) ----
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ---- Database (later) ----
DATABASE_URL=postgresql://localhost:5432/sentinelq
