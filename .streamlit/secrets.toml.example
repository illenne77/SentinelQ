# Streamlit Cloud secrets 설정 예시
# 실제 값은 share.streamlit.io 앱 대시보드 > Settings > Secrets 에서 설정
# 이 파일은 예시용으로만 커밋됨 — secrets.toml (실제 값) 은 gitignore 처리됨

# DART API (공시 모니터링 필수)
# opendart.fss.or.kr 에서 무료 발급
DART_API_KEY = "your_dart_api_key_here"

# KIS API (포트폴리오 자동 조회 — 선택사항)
# 한국투자증권 OpenAPI 신청 후 발급
KIS_APP_KEY = "your_kis_app_key_here"
KIS_APP_SECRET = "your_kis_app_secret_here"
KIS_ACCOUNT = "ACCOUNT_NUMBER_HERE"

# 텔레그램 알림 (선택사항)
# BotFather 에서 봇 생성 후 토큰 발급
TELEGRAM_BOT_TOKEN = "1234567890:AAAA..."
TELEGRAM_CHAT_ID = "123456789"
