# ---- OS ----
Thumbs.db
Desktop.ini
.DS_Store

# ---- Editors / IDE ----
.vscode/
.idea/
*.swp
*.swo
*~

# ---- Python ----
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.env
.env.*
!.env.example

# ---- Node (future) ----
node_modules/
npm-debug.log*

# ---- Build / dist ----
dist/
build/
*.log

# ---- Secrets — NEVER commit ----
# KIS API keys, broker tokens, anything resembling credentials
secrets/
*.pem
*.key
*.pfx
*credentials*
*appkey*
*appsecret*
kis_token*.json

# ---- Data ----
# Raw market data and backtest artifacts are not committed (size + license)
data/
*.parquet
research/**/_cache/
*.feather
*.duckdb
*.sqlite
*.db
research/**/results/
research/**/*.csv
research/**/*.png
!research/**/sample_*.csv

# ---- Office temp files ----
~$*.docx
~$*.xlsx
~$*.pptx

# ---- Doc backups (kept locally only) ----
Doc/_backup_*.docx

# ---- Misc ----
*.tmp
*.bak
.coverage
htmlcov/

# ---- Claude Code harness (개인 기능·환경 의존) ----
# DiRux 01-harness-validation-strategy 정책 차용 — .claude/만 미추적,
# CLAUDE.md는 mandate·기술스택 정보이므로 commit 대상.
# 예외: baseline.json은 SSOT이므로 git 추적 (CI 회귀 floor 검증에 필요).
.claude/*
!.claude/baseline.json

# ---- Phase 3 본인 거래내역 (절대 commit 금지) ----
data/private/
