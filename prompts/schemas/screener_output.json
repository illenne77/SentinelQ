{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "sentinelq/screener_output.json",
  "title": "Screener Output",
  "type": "object",
  "additionalProperties": false,
  "required": ["as_of", "alpha_id", "ranking", "summary", "prompt_version"],
  "properties": {
    "as_of":    { "type": "string", "format": "date-time" },
    "alpha_id": { "type": "string", "enum": ["A1","A2","A3","A4","A5","A6","A7"] },
    "ranking": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["ticker", "bucket", "rank", "justification"],
        "properties": {
          "ticker":         { "type": "string", "pattern": "^[0-9]{6}$" },
          "bucket":         { "type": "string", "enum": ["STRONG","WEAK","REJECT"] },
          "rank":           { "type": "integer", "minimum": 1 },
          "justification":  { "type": "string", "minLength": 5, "maxLength": 200 },
          "flags": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "DATA_GAP", "STALE_SNAPSHOT", "DUPLICATE_SECTOR",
                "GATE_BORDERLINE", "LOW_LIQUIDITY", "OTHER"
              ]
            },
            "uniqueItems": true
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strong_count", "weak_count", "reject_count"],
      "properties": {
        "strong_count": { "type": "integer", "minimum": 0 },
        "weak_count":   { "type": "integer", "minimum": 0 },
        "reject_count": { "type": "integer", "minimum": 0 }
      }
    },
    "notes":          { "type": "string", "maxLength": 200 },
    "prompt_version": { "type": "string", "pattern": "^screener_v[0-9]+\\.[0-9]+$" }
  }
}
